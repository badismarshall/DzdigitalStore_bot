# Marshall BOT — ENVIRONMENT CONFIGURATION
# Copy this file to ".env" and fill in your real values.
# NEVER commit your real .env file to version control.
# ==========================================================

# --- Telegram Bot Token (from @BotFather) ---
BOT_TOKEN=6388939970:AAHy1LpEYMBo5Sqj_wLPkwAOf5ivADCYMwA

# --- Admin Telegram numeric user IDs (comma-separated) ---
# You can get your numeric ID from @userinfobot
ADMIN_IDS=996385564,7145448613

# --- Required Membership ---
# Use PUBLIC usernames WITHOUT the leading "@".
# The bot itself MUST be an admin of both the channel and the group
# so it can verify membership.
REQUIRED_CHANNEL=DIGlTALDZ
REQUIRED_GROUP=degitaldz

# --- Notification Target ---
# Where order/deposit/stock notifications are sent.
# Use a public @username (without @) OR a numeric chat id (e.g. -1001234567890).
# Often this is the same as your group. The bot must be a member/admin there.
NOTIFY_CHAT=degitaldz

# --- Crypto Wallet Addresses (shown to users on the deposit screen) ---
# Add as many networks as you want, separated by a semicolon ";".
# Format per entry:  LABEL|ADDRESS
CRYPTO_WALLETS=USDT (BEP20)|0x5983623f1f18df887ac8a65d2b5480cad447f7b6;

# --- Referral reward (points granted to inviter per verified new user) ---
REFERRAL_POINTS=10

# --- Database location (SQLite) ---
# Default keeps the DB inside the data/ directory.
DATABASE_URL=sqlite+aiosqlite:///data/nazzshop.db

# --- Currency symbol used for the money balance ---
CURRENCY_SYMBOL=$

TURSO_DATABASE_URL=libsql://marshallbotshop-badismarshall.aws-eu-west-1.turso.io
